{
  "name": "bootstrap-ui-sounds",
  "version": "0.0.3",
  "description": "UI Sounds for Bootstrap",
  "main": "js/bootstrap-ui-sounds.js",
  "unpkg": "js/bootstrap-ui-sounds.min.js",
  "jsdelivr": "js/bootstrap-ui-sounds.min.js",
  "sideEffects": true,
  "keywords": [
    "web-audio",
    "audio-feedback",
    "bootstrap-5"
  ],
  "homepage": "https://coliff.github.io/bootstrap-ui-sounds/docs/",
  "bugs": {
    "url": "https://github.com/coliff/bootstrap-ui-sounds/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coliff/bootstrap-ui-sounds.git"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/coliff"
    },
    {
      "type": "PayPal",
      "url": "https://paypal.me/coliff"
    }
  ],
  "license": "MIT",
  "files": [
    "js"
  ],
  "author": "Christian Oliff (https://christianoliff.com)",
  "scripts": {
    "build": "npm run lint-js && node build.mjs",
    "lint": "npm run lint-html && npm run lint-js && npm run prettier && npm run spellcheck && node build.mjs",
    "lint-html": "npx htmlhint **/*.html",
    "lint-js": "npx eslint@8 build.mjs js/bootstrap-ui-sounds.js --fix",
    "pa11y": "npx pa11y https://coliff.github.io/bootstrap-ui-sounds/",
    "prettier": "npx prettier --write \"*.{html,js,json,mjs,yml}\"",
    "serve": "npm run lint-js && npm run build && npx serve . -l 3000",
    "spellcheck": "npx cspell \"*.{html,js,json,md,mjs,txt,yml}\" --no-progress"
  },
  "devDependencies": {
    "terser": "5.46.2"
  },
  "volta": {
    "node": "24.14.0"
  }
}
