  "scripts": {
    "build": "node build.mjs",
    "lint": "npm run lint-html && npm run lint-js",
    "lint-html": "npx htmlhint **/*.html",
    "lint-js": "npx eslint@8 **/*.mjs --fix",
    "pa11y": "npx pa11y https://coliff.github.io/bootstrap-ui-sounds/",
    "prettier": "npx prettier --write \"docs/**/*.{html,css,js}\"",
    "serve": "npx serve docs",
    "spellcheck": "npx cspell \"**/*.html\" --no-progress"
  },
  "devDependencies": {
    "terser": "5.46.1"
  },
  "volta": {
    "node": "24.10.0"
  }
